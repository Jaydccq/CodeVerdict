# load-tests/.env.example
# Copy to .env.local and fill in values before running tests

# ── Shared ──────────────────────────────────────────────
# For local: http://localhost:3000
# For production: https://your-railway-domain.up.railway.app
BASE_URL=http://localhost:3101

# Admin credentials (needed by k6 setup() to create exam)
ADMIN_EMAIL=testadmin@gmail.com
ADMIN_PASSWORD=123456

# ── k6 load test ────────────────────────────────────────
VUS=120
THINK_TIME=15

# Throttler - raise before load test, restore after
# Requires server restart / redeploy to take effect
THROTTLE_LIMIT=10000
THROTTLE_TTL=60000

# DB pool - raise before load test
DB_POOL_SIZE=50

