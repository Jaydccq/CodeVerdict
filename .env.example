# ── App database ──────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=exam_platform

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
APP_NAME=CodeVerdict

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=300000

# ── Judge0 ────────────────────────────────────────────────────────────────────
# Default points to a host-provided Judge0 endpoint. For the bundled local
# Judge0 stack on x86_64 hosts, run:
#   docker compose --profile judge0-local up --build
# and set:
#   JUDGE0_URL=http://judge0-server:2358
JUDGE0_URL=http://host.docker.internal:2358

# ── Admin setup ───────────────────────────────────────────────────────────────
ADMIN_SETUP_KEY=change_this_to_a_secure_key

# ── Leaderboard ──────────────────────────────────────────────────────────────
LEADERBOARD_CRON=0 */5 * * * *

# ── Slack Alerts (optional) ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=

# ── CORS (comma-separated local origins or blank when served by same process) ─
CORS_ORIGIN=
