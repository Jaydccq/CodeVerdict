# ── App database ──────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=exam_platform

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
APP_NAME=CodeVerdict

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=300000

# ── Judge0 ────────────────────────────────────────────────────────────────────
JUDGE0_URL=http://judge0-server:2358

# ── Admin setup ───────────────────────────────────────────────────────────────
ADMIN_SETUP_KEY=change_this_to_a_secure_key

# ── Leaderboard ──────────────────────────────────────────────────────────────
LEADERBOARD_CRON=0 */5 * * * *

# ── Slack Alerts (optional) ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=

# ── CORS (leave blank in production - frontend is served by the same process) ─
CORS_ORIGIN=
