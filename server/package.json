{
  "name": "codeverdict-server",
  "version": "1.0.0",
  "description": "CodeVerdict backend - NestJS 11 API for the open-source coding exam platform with Judge0 integration and ICPC scoring",
  "author": "ATOA Payments Limited",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/ATOAPaymentsLimited/CodeVerdict#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ATOAPaymentsLimited/CodeVerdict.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/ATOAPaymentsLimited/CodeVerdict/issues"
  },
  "keywords": [
    "coding-exam",
    "exam-platform",
    "nestjs",
    "judge0",
    "icpc",
    "leaderboard",
    "typeorm",
    "postgresql",
    "open-source",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/typeorm.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/typeorm.config.ts",
    "migration:run:prod": "typeorm migration:run -d dist/config/typeorm.config.js",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/typeorm.config.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "test:e2e": "jest --config jest-e2e.config.ts --runInBand --forceExit",
    "validate:problems": "node scripts/validate-problems.mjs",
    "import:problem": "node scripts/import-problem.mjs",
    "smoke:practice": "node scripts/smoke-practice.mjs",
    "mock:judge0:practice": "node scripts/mock-judge0-practice.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@slack/web-api": "^7.15.0",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
