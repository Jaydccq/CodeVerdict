# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=exam_platform

# Application
NODE_ENV=dev
PORT=3000
APP_NAME=CodeVerdict

# Auth
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=300000

# Judge0 (RapidAPI)
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Admin Setup
ADMIN_SETUP_KEY=your_admin_setup_key

# Leaderboard
LEADERBOARD_CRON=0 */5 * * * *

# CORS (set to frontend URL for local dev, leave blank in production)
CORS_ORIGIN=http://localhost:5173

# Slack Alerts (optional - leave blank to disable)
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=
