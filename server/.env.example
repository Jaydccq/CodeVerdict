# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=exam_platform

# Application
NODE_ENV=dev
PORT=3000
HOST=127.0.0.1
APP_NAME=CodeVerdict

# Auth
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=300000

# Judge0 (local or RapidAPI)
JUDGE0_URL=http://localhost:2358
RAPIDAPI_KEY=
RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Admin Setup (legacy admin routes only)
ADMIN_SETUP_KEY=local-admin-setup-key

# Leaderboard
LEADERBOARD_CRON=0 */5 * * * *

# CORS (comma-separated local origins)
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Slack Alerts (optional - leave blank to disable)
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=
